#Functions

```{r Functions}
tidy_comet_data <- function(raw_data)
{
  return(raw_data |>
        mutate(x = `Distance_.microns.`) |>
        mutate(y = Gray_Value) |>
          # To normalize the x distance to be 0 at the peak and negative
          #   in front of the peak and positive behind the peak
          #   we subtract the x value at the peak from all the x values
        mutate(norm_x = x-x[which.max(y)]) |>
          # To normalize the y values we subtract the minimum value from
          #   all y values to set the lowest values to 0
          #   then we divide all values by the maximum y value
          #   this scales the values 0-1 then we multiple by 100 to get percent
        mutate(norm_y = ((y-min(y))/max(y))*100) |>
          # To get each region of the comet for curve fitting
          #   take the normalized x values within a range
          #   set all other values to 'na'
        mutate(head_x = if_else(norm_x>(head_start) & norm_x<head_end, as.character(norm_x), 'na')) |>
        mutate(tail_x = if_else(norm_x>tail_start & norm_x<tail_end, as.character(norm_x), 'na')) |>
        mutate(lattice_x = if_else(norm_x>lattice_start, as.character(norm_x), 'na')))
  
}

