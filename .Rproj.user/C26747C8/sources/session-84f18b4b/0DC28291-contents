#Data I/O

```{r Data import, tidying, and saving}
# Import the data by looping through .csv files in a directory
# prompt the user to choose a .csv file in the desired parent directory
# we will loop through all.csv files in this directory ( maybe subdirectories)
filepath = file.choose()
filepath_split = SplitPath(filepath)
files_in_dir = list.files(path=filepath_split$dirname,
           pattern='^\\s*[track]+(?:\\s*[csv]+)',
           all.files=F,
           full.names=T,
           recursive=T
           )

for(i in 1:length(files_in_dir))
{
  filepath_to_csv <- files_in_dir[i]
  if(str_detect(filepath_to_csv, pattern=".csv"))
  {
    comet <- read.csv(filepath_to_csv)
    comet_tidy <- tidy_comet_data(comet)
    filepath_to_csv_split = SplitPath(filepath_to_csv)
    out_filepath_all =  paste(filepath_to_csv_split$fullpath,
                "all_normalized_",
                filepath_to_csv_split$fullfilename,
                sep="")
    write.csv(comet_tidy, out_filepath_all)
    out_filepath_head =  paste(filepath_to_csv_split$fullpath,
                "head_normalized_",
                filepath_to_csv_split$fullfilename,
                sep="")
    write.csv(extract_comet_head(comet_tidy), out_filepath_head)
    out_filepath_tail =  paste(filepath_to_csv_split$fullpath,
                "tail_normalized_",
                filepath_to_csv_split$fullfilename,
                sep="")
    write.csv(extract_comet_tail(comet_tidy), out_filepath_tail)
    out_filepath_lattice =  paste(filepath_to_csv_split$fullpath,
                "lattice_normalized_",
                filepath_to_csv_split$fullfilename,
                sep="")
    write.csv(extract_comet_lattice(comet_tidy), out_filepath_lattice)
  }
}
```
